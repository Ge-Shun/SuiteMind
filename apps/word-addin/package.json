{
  "name": "@suitemind/word-addin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev-certs": "office-addin-dev-certs install",
    "dev:e2e": "vite --mode test --host 127.0.0.1 --port 3000 --strictPort true",
    "dev-server": "vite",
    "e2e": "playwright test",
    "fake-provider": "node ../../scripts/fake-provider.mjs",
    "preview": "vite preview",
    "sideload": "office-addin-debugging start manifest.xml desktop --app word --debug-method direct --no-live-reload --dev-server-port 3000",
    "stop": "office-addin-debugging stop manifest.xml",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate:manifest": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@suitemind/contracts": "*",
    "diff": "^9.0.0",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/office-js": "^1.0.599",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "office-addin-debugging": "^6.1.2",
    "office-addin-dev-certs": "^2.0.10",
    "office-addin-manifest": "^2.1.6",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
