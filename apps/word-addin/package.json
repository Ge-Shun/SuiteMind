{
  "name": "@suitemind/word-addin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev-server": "vite",
    "preview": "vite preview",
    "sideload": "office-addin-debugging start manifest.xml desktop --app word --debug-method direct --no-live-reload --dev-server-port 3000",
    "stop": "office-addin-debugging stop manifest.xml",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate:manifest": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@suitemind/contracts": "*",
    "diff": "^8.0.2",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/diff": "^7.0.2",
    "@types/office-js": "^1.0.599",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "office-addin-dev-certs": "^2.0.10",
    "office-addin-debugging": "^6.1.2",
    "office-addin-manifest": "^2.1.6",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
