{
  "name": "suitemind",
  "version": "0.1.0",
  "private": true,
  "description": "AI workspace for Microsoft Word",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w @suitemind/word-addin",
    "dev:word": "npm run dev -w @suitemind/word-addin",
    "e2e:word": "npm run e2e -w @suitemind/word-addin",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:production-manifest": "node scripts/generate-production-manifest.mjs",
    "proxy:certs": "npm run dev-certs -w @suitemind/word-addin",
    "proxy:local": "node scripts/local-provider-proxy.mjs",
    "sideload:word": "npm run sideload -w @suitemind/word-addin",
    "stop:word": "npm run stop -w @suitemind/word-addin",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
